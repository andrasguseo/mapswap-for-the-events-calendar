{
  "name": "andras-guseo/alternative-maps-for-tec",
  "minimum-stability": "stable",
  "type": "wordpress-plugin",
  "authors": [
    {
      "name": "Andras",
      "email": "hello@andrasguseo.com"
    }
  ],
  "prefer-stable": true,
  "config": {
    "preferred-install": "dist",
    "platform": {
      "php": "8.0"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "autoload": {
    "psr-4": {
      "AGU\\Alternative_Maps_For_Tec\\": "src/Alternative_Maps_For_Tec"
    }
  },
  "require-dev": {
    "php": ">=8.0",
    "automattic/vipwpcs": "^3.0"
  }
}
